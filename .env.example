# === Instagram / Meta (obligatorio) ===
INSTAGRAM_APP_ID=tu_instagram_app_id
INSTAGRAM_APP_SECRET=tu_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://tudominio.com/api/instagram/callback
FRONTEND_URL=https://tudominio.com

# === Base de datos (obligatorio) ===
DATABASE_URL=postgres://usuario:password@host:5432/basededatos

# === Seguridad (obligatorio) ===
# Clave para cifrar los tokens (AES-256-GCM). 64 caracteres hex. Genérala con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=pega_aqui_64_caracteres_hex
# Secreto para proteger el cron de refresco. Cualquier cadena larga y aleatoria:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=pega_aqui_una_cadena_aleatoria

# === IA (para el generador de ideas) ===
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# === Competencia / Business Discovery (opcional) ===
GRAPH_API_VERSION=v25.0
AGENCY_IG_ID=
AGENCY_FB_TOKEN=

# === Almacenamiento de media (para publicar imágenes/videos) ===
# Compatible con S3: Cloudflare R2 (recomendado), AWS S3, Supabase Storage, etc.
S3_ENDPOINT=https://TU_CUENTA.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=pulso-media
S3_ACCESS_KEY_ID=tu_access_key
S3_SECRET_ACCESS_KEY=tu_secret_key
# URL pública del bucket/CDN (Instagram descarga la media desde aquí):
S3_PUBLIC_BASE_URL=https://media.tudominio.com
